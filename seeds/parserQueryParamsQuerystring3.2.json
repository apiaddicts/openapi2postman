{
  "openapi": "3.2.0",
  "info": { "version": "1.0.0", "title": "Querystring Param API" },
  "servers": [{ "url": "https://api.example.com/v1" }],
  "paths": {
    "/search": {
      "get": {
        "operationId": "search",
        "parameters": [
          {
            "name": "q",
